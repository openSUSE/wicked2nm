[connection]
id=eth10
uuid=620219d9-75b4-41db-a1d9-45e3f58fbc8e
type=ethernet
interface-name=eth10

[ethernet]

[match]

[ipv4]
dhcp-client-id=ipv6-duid
dhcp-iaid=mac
dhcp-send-hostname-deprecated=false
dhcp-send-hostname=0
dhcp-send-release=0
ignore-auto-dns=true
method=auto

[ipv6]
addr-gen-mode=default
dhcp-duid=llt
dhcp-iaid=mac
dhcp-send-hostname-deprecated=false
dhcp-send-hostname=0
dhcp-send-release=0
ignore-auto-dns=true
ip6-privacy=1
method=auto

[proxy]
