[connection]
id=team0
type=bond
autoconnect-ports=1
interface-name=team0

[ethernet]

[bond]
arp_interval=500
arp_missed_max=5
fail_over_mac=follow
mode=active-backup
ns_ip6_target=2001:db8::254

[match]

[ipv4]
method=disabled

[ipv6]
addr-gen-mode=default
address1=2001:db8::1/64
ip6-privacy=1
method=manual

[proxy]
