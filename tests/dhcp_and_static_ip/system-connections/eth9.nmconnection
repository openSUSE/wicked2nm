[connection]
id=eth9
uuid=5b638b23-00c3-4ed4-94b5-81c806af7585
type=ethernet
interface-name=eth9

[ethernet]

[match]

[ipv4]
address1=192.168.99.24/24
address2=192.168.100.24/24
dhcp-client-id=ipv6-duid
dhcp-iaid=mac
dhcp-send-hostname-deprecated=false
dhcp-send-hostname=0
dhcp-send-release=0
dns-priority=20
method=auto

[ipv6]
addr-gen-mode=default
address1=fd00::192:168:99:24/64
address2=fd00::192:168:100:24/64
dhcp-duid=llt
dhcp-iaid=mac
dhcp-send-hostname-deprecated=false
dhcp-send-hostname=0
dhcp-send-release=0
dns-priority=20
ip6-privacy=1
method=auto

[proxy]
