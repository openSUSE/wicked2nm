<interface origin="compat:suse:/tests/team_activebackup_notifications2/netconfig/ifcfg-eth9">
  <name>eth9</name>
  <control>
    <mode>hotplug</mode>
  </control>
  <link>
    <master>team0</master>
    <port type="team"/>
  </link>
  <ipv4>
    <enabled>false</enabled>
  </ipv4>
  <ipv6>
    <enabled>false</enabled>
  </ipv6>
</interface>
<interface origin="compat:suse:/tests/team_activebackup_notifications2/netconfig/ifcfg-team0">
  <name>team0</name>
  <control>
    <mode>boot</mode>
  </control>
  <team>
    <address>02:11:22:33:44:55</address>
    <notify_peers>
      <count>5</count>
      <interval>200</interval>
    </notify_peers>
    <mcast_rejoin>
      <count>3</count>
    </mcast_rejoin>
    <runner name="activebackup">
      <hwaddr_policy>by_active</hwaddr_policy>
    </runner>
    <link_watch>
      <watch name="ethtool">
        <delay_up>50</delay_up>
        <delay_down>100</delay_down>
      </watch>
    </link_watch>
  </team>
  <link/>
  <ipv4>
    <enabled>true</enabled>
  </ipv4>
  <ipv4:static>
    <address>
      <local>192.168.200.1/24</local>
    </address>
  </ipv4:static>
  <ipv6>
    <enabled>true</enabled>
    <privacy>prefer-public</privacy>
  </ipv6>
</interface>
<interface origin="compat:suse:/tests/team_activebackup_notifications2/netconfig/ifcfg-eth8">
  <name>eth8</name>
  <control>
    <mode>hotplug</mode>
  </control>
  <link>
    <master>team0</master>
    <port type="team"/>
  </link>
  <ipv4>
    <enabled>false</enabled>
  </ipv4>
  <ipv6>
    <enabled>false</enabled>
  </ipv6>
</interface>
