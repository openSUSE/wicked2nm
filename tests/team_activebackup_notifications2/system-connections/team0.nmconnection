[connection]
id=team0
type=bond
autoconnect-slaves=1
interface-name=team0

[ethernet]
cloned-mac-address=02:11:22:33:44:55

[bond]
downdelay=100
fail_over_mac=active
miimon=50
mode=active-backup
num_grat_arp=5
num_unsol_na=5
peer_notif_delay=200
resend_igmp=3
updelay=50

[match]

[ipv4]
address1=192.168.200.1/24
method=manual

[ipv6]
addr-gen-mode=default
ip6-privacy=1
method=auto

[proxy]
