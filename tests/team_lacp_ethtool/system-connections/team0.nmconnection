[connection]
id=team0
type=bond
autoconnect-ports=1
interface-name=team0

[ethernet]

[bond]
ad_actor_sys_prio=100
ad_select=bandwidth
downdelay=20
lacp_active=0
lacp_rate=fast
miimon=10
min_links=2
mode=802.3ad
updelay=10
xmit_hash_policy=layer2+3

[match]

[ipv4]
address1=192.168.100.1/24
method=manual

[ipv6]
addr-gen-mode=default
ip6-privacy=1
method=auto

[proxy]
